{
  "dashboard": {
    "title": "Sentinel Overview",
    "description": "Security event processing pipeline metrics",
    "panels": [
      {
        "title": "Events Processed / sec",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(events_processed_total[1m])",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
      },
      {
        "title": "Processing Latency (P50/P95/P99)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(processing_latency_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(processing_latency_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(processing_latency_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ],
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
      },
      {
        "title": "Alerts Fired / min",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(alerts_fired_total[1m]) * 60",
            "legendFormat": "{{severity}}"
          }
        ],
        "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 }
      },
      {
        "title": "Circuit Breaker State",
        "type": "stat",
        "targets": [
          {
            "expr": "circuit_breaker_state",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
        "description": "0=closed, 1=open, 2=half-open"
      },
      {
        "title": "Worker Pool Queue Depth",
        "type": "gauge",
        "targets": [
          {
            "expr": "worker_pool_queue_depth",
            "legendFormat": "{{service}}"
          }
        ],
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 }
      },
      {
        "title": "Kafka Consumer Lag",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_lag",
            "legendFormat": "{{topic}} - {{group}}"
          }
        ],
        "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 }
      }
    ]
  }
}
